# ── Backend (set these on Render) ────────────────────────────────────────────

# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated list of allowed frontend origins (no trailing slashes)
# Set this to your Vercel/custom domain once deployed
ALLOWED_ORIGINS=https://academiqhq.com,https://www.academiqhq.com

# ── Frontend (set these on Vercel) ───────────────────────────────────────────

# Full URL of the Render backend — no trailing slash
# e.g. https://academiqhq-api.onrender.com
VITE_API_URL=https://your-backend.onrender.com
